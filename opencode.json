{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "agent-prompts/default.md"
    },
    "advisor": {
      "model": "openai/gpt-5.5",
      "mode": "subagent",
      "prompt": "agent-prompts/general.md"
    },
    "plan": {
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "agent-prompts/default.md"
    },
    "general": {
      "prompt": "agent-prompts/general.md",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free"
    },
    "explore": {
      "prompt": "agent-prompts/explore.md",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free"
    },
    "compaction": {
      "prompt": "agent-prompts/compaction.md",
      "model": "opencode/deepseek-v4-flash-free"
    },
    "quick": {
      "model": "opencode-go/deepseek-v4-pro"
    }
  },
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.docker/**": "deny",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "edit": {
      "~/.ssh/**": "deny",
      "~/.docker/**": "deny"
    },
    "bash": {
      "git *": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git grep*": "allow",
      "git stash list*": "allow",
      "git stash show*": "allow",
      "git reflog*": "allow",
      "git describe*": "allow",
      "git ls-files*": "allow",
      "git rev-parse*": "allow",
      "git rev-list*": "allow",
      "git cat-file*": "allow",
      "git ls-tree*": "allow",
      "git shortlog*": "allow",
      "git whatchanged*": "allow",
      "git for-each-ref*": "allow",
      "git name-rev*": "allow",
      "git cherry*": "allow",
      "git merge-base*": "allow",
      "git check-attr*": "allow",
      "git check-ignore*": "allow",
      "git fsck*": "allow",
      "git help*": "allow",
      "git version*": "allow",
      "rm *credentials*": "deny",
      "rm *.env*": "deny"
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp local server",
      "options": {
        "baseURL": "http://127.0.0.1:9090/v1"
      },
      "models": {
        "llama-cpp-local": {
          "name": "Local via llama.cpp",
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 262144,
            "output": 32000
          }
        }
      }
    }
  },
  "share": "disabled",
  "plugin": [
    "/Users/nnn/code-reference/magic-compact"
  ]
}
